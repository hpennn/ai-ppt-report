---
import Layout from '../layouts/Layout.astro';
---

<Layout title="AI PPT / 工作汇报生成器">
  <!-- Header -->
  <header class="bg-white border-b border-gray-200 no-print">
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-gradient-to-br from-primary-500 to-primary-700 rounded-xl flex items-center justify-center">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <div>
          <h1 class="text-xl font-bold text-gray-900">AI PPT & 汇报生成器</h1>
          <p class="text-xs text-gray-500">智能创作，高效呈现</p>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <a href="/ppt" class="text-sm text-gray-600 hover:text-primary-600 transition-smooth px-3 py-2">PPT 生成</a>
        <a href="/report" class="text-sm text-gray-600 hover:text-primary-600 transition-smooth px-3 py-2">工作汇报</a>
      </div>
    </div>
  </header>

  <!-- Hero Section -->
  <main class="max-w-6xl mx-auto px-6 py-16">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        AI 驱动的<span class="text-primary-600">智能创作</span>工具
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        一键生成专业 PPT 演示文稿和高质量工作汇报，让 AI 为你分担创作压力
      </p>
    </div>

    <!-- Cards -->
    <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      <!-- PPT Card -->
      <a href="/ppt" class="card-hover block bg-white rounded-2xl border border-gray-200 overflow-hidden group">
        <div class="h-48 bg-gradient-to-br from-primary-500 via-primary-600 to-blue-800 flex items-center justify-center relative overflow-hidden">
          <div class="absolute inset-0 opacity-20">
            <div class="absolute top-4 left-4 w-32 h-20 bg-white/30 rounded-lg transform -rotate-6"></div>
            <div class="absolute bottom-4 right-4 w-28 h-18 bg-white/20 rounded-lg transform rotate-3"></div>
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-40 h-24 bg-white/10 rounded-lg"></div>
          </div>
          <svg class="w-20 h-20 text-white/90 relative z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <div class="p-6">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-2xl">📊</span>
            <h3 class="text-xl font-bold text-gray-900 group-hover:text-primary-600 transition-smooth">AI PPT 生成</h3>
          </div>
          <p class="text-gray-600 text-sm mb-4">
            输入主题，AI 自动生成专业演示文稿。支持 5 种主题风格、全屏演示模式、一键导出 HTML。
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="px-2 py-1 bg-primary-50 text-primary-700 text-xs rounded-full">5 种主题</span>
            <span class="px-2 py-1 bg-primary-50 text-primary-700 text-xs rounded-full">全屏演示</span>
            <span class="px-2 py-1 bg-primary-50 text-primary-700 text-xs rounded-full">导出 HTML</span>
            <span class="px-2 py-1 bg-primary-50 text-primary-700 text-xs rounded-full">流式生成</span>
          </div>
        </div>
      </a>

      <!-- Report Card -->
      <a href="/report" class="card-hover block bg-white rounded-2xl border border-gray-200 overflow-hidden group">
        <div class="h-48 bg-gradient-to-br from-emerald-500 via-teal-600 to-cyan-700 flex items-center justify-center relative overflow-hidden">
          <div class="absolute inset-0 opacity-20">
            <div class="absolute top-6 left-6 w-40 h-2 bg-white/40 rounded"></div>
            <div class="absolute top-12 left-6 w-32 h-2 bg-white/30 rounded"></div>
            <div class="absolute top-18 left-6 w-36 h-2 bg-white/25 rounded"></div>
            <div class="absolute bottom-8 right-8 w-24 h-24 bg-white/15 rounded-full"></div>
          </div>
          <svg class="w-20 h-20 text-white/90 relative z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
        </div>
        <div class="p-6">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-2xl">📝</span>
            <h3 class="text-xl font-bold text-gray-900 group-hover:text-emerald-600 transition-smooth">工作汇报生成器</h3>
          </div>
          <p class="text-gray-600 text-sm mb-4">
            支持周报/月报/季度/年度总结，5 种表达风格。一键复制、导出 Markdown、打印友好。
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="px-2 py-1 bg-emerald-50 text-emerald-700 text-xs rounded-full">4 种类型</span>
            <span class="px-2 py-1 bg-emerald-50 text-emerald-700 text-xs rounded-full">5 种风格</span>
            <span class="px-2 py-1 bg-emerald-50 text-emerald-700 text-xs rounded-full">导出 Word</span>
            <span class="px-2 py-1 bg-emerald-50 text-emerald-700 text-xs rounded-full">在线编辑</span>
          </div>
        </div>
      </a>
    </div>

    <!-- Features -->
    <div class="mt-20 text-center">
      <h3 class="text-2xl font-bold text-gray-900 mb-8">为什么选择我们？</h3>
      <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <div class="p-6 bg-white rounded-xl border border-gray-100">
          <div class="w-12 h-12 bg-primary-100 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h4 class="font-semibold text-gray-900 mb-2">极速生成</h4>
          <p class="text-sm text-gray-600">AI 流式输出，几秒内生成完整内容</p>
        </div>
        <div class="p-6 bg-white rounded-xl border border-gray-100">
          <div class="w-12 h-12 bg-emerald-100 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6z"/>
            </svg>
          </div>
          <h4 class="font-semibold text-gray-900 mb-2">专业品质</h4>
          <p class="text-sm text-gray-600">多种风格模板，输出专业级内容</p>
        </div>
        <div class="p-6 bg-white rounded-xl border border-gray-100">
          <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>
            </svg>
          </div>
          <h4 class="font-semibold text-gray-900 mb-2">灵活定制</h4>
          <p class="text-sm text-gray-600">支持编辑调整，自由切换风格</p>
        </div>
      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer class="border-t border-gray-200 mt-20 no-print">
    <div class="max-w-6xl mx-auto px-6 py-8 text-center text-sm text-gray-500">
      <p>Powered by 豆包大模型 · Built with Astro & Tailwind CSS</p>
    </div>
  </footer>
</Layout>
