---
import Layout from '../layouts/Layout.astro';
---

<Layout title="AI PPT / 工作汇报生成器" currentPage="home">
  <div class="max-w-3xl mx-auto px-6 py-10">
    <!-- AI Welcome Message -->
    <div class="flex gap-3 mb-8">
      <div class="ai-avatar w-9 h-9 rounded-xl flex items-center justify-center shrink-0 shadow-lg shadow-blue-500/20">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
        </svg>
      </div>
      <div class="ai-bubble px-5 py-4 max-w-xl">
        <p class="text-gray-800 text-base leading-relaxed">
          👋 你好！我是 AI 创作助手，可以帮你快速生成专业内容：
        </p>
        <div class="flex flex-wrap gap-2 mt-3">
          <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-blue-50 text-blue-700 text-xs rounded-full border border-blue-100">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            PPT 演示文稿
          </span>
          <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-emerald-50 text-emerald-700 text-xs rounded-full border border-emerald-100">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            工作汇报
          </span>
        </div>
        <p class="text-gray-600 text-sm mt-3">选择一个功能开始吧 ✨</p>
      </div>
    </div>

    <!-- Quick Action Cards -->
    <div class="grid md:grid-cols-2 gap-4 mb-10">
      <!-- PPT Card -->
      <a href="/ppt" class="card-hover group bg-white rounded-2xl border border-gray-200 overflow-hidden">
        <div class="h-36 bg-gradient-to-br from-primary-500 via-primary-600 to-blue-800 flex items-center justify-center relative overflow-hidden">
          <div class="absolute inset-0 opacity-20">
            <div class="absolute top-4 left-4 w-24 h-14 bg-white/30 rounded-lg transform -rotate-6"></div>
            <div class="absolute bottom-3 right-3 w-20 h-12 bg-white/20 rounded-lg transform rotate-3"></div>
          </div>
          <svg class="w-14 h-14 text-white/90 relative z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <div class="p-4">
          <div class="flex items-center gap-2 mb-1.5">
            <span class="text-lg">📊</span>
            <h3 class="text-base font-bold text-gray-900 group-hover:text-primary-600 transition-smooth">AI PPT 生成</h3>
          </div>
          <p class="text-gray-500 text-xs mb-3">
            输入主题，AI 自动生成专业演示文稿，支持 5 种主题风格与全屏演示。
          </p>
          <div class="flex flex-wrap gap-1.5">
            <span class="px-2 py-0.5 bg-primary-50 text-primary-700 text-[10px] rounded-full">5 种主题</span>
            <span class="px-2 py-0.5 bg-primary-50 text-primary-700 text-[10px] rounded-full">全屏演示</span>
            <span class="px-2 py-0.5 bg-primary-50 text-primary-700 text-[10px] rounded-full">导出 HTML</span>
          </div>
        </div>
      </a>

      <!-- Report Card -->
      <a href="/report" class="card-hover group bg-white rounded-2xl border border-gray-200 overflow-hidden">
        <div class="h-36 bg-gradient-to-br from-emerald-500 via-teal-600 to-cyan-700 flex items-center justify-center relative overflow-hidden">
          <div class="absolute inset-0 opacity-20">
            <div class="absolute top-5 left-5 w-32 h-1.5 bg-white/40 rounded"></div>
            <div class="absolute top-9 left-5 w-24 h-1.5 bg-white/30 rounded"></div>
            <div class="absolute bottom-6 right-6 w-16 h-16 bg-white/15 rounded-full"></div>
          </div>
          <svg class="w-14 h-14 text-white/90 relative z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
        </div>
        <div class="p-4">
          <div class="flex items-center gap-2 mb-1.5">
            <span class="text-lg">📝</span>
            <h3 class="text-base font-bold text-gray-900 group-hover:text-emerald-600 transition-smooth">工作汇报生成器</h3>
          </div>
          <p class="text-gray-500 text-xs mb-3">
            周报/月报/季度/年度总结，5 种表达风格，一键复制导出。
          </p>
          <div class="flex flex-wrap gap-1.5">
            <span class="px-2 py-0.5 bg-emerald-50 text-emerald-700 text-[10px] rounded-full">4 种类型</span>
            <span class="px-2 py-0.5 bg-emerald-50 text-emerald-700 text-[10px] rounded-full">5 种风格</span>
            <span class="px-2 py-0.5 bg-emerald-50 text-emerald-700 text-[10px] rounded-full">导出 Word</span>
          </div>
        </div>
      </a>
    </div>

    <!-- Features Section -->
    <div class="mb-8">
      <div class="flex gap-3 mb-5">
        <div class="ai-avatar w-7 h-7 rounded-lg flex items-center justify-center shrink-0">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <p class="text-sm text-gray-500 self-center">以下是我的核心能力：</p>
      </div>

      <div class="grid grid-cols-3 gap-3">
        <div class="bg-white rounded-xl border border-gray-100 p-4 text-center">
          <div class="w-10 h-10 bg-primary-100 rounded-xl flex items-center justify-center mx-auto mb-3">
            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h4 class="font-semibold text-gray-900 text-sm mb-1">极速生成</h4>
          <p class="text-xs text-gray-500">AI 流式输出，几秒内生成完整内容</p>
        </div>
        <div class="bg-white rounded-xl border border-gray-100 p-4 text-center">
          <div class="w-10 h-10 bg-emerald-100 rounded-xl flex items-center justify-center mx-auto mb-3">
            <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6z"/>
            </svg>
          </div>
          <h4 class="font-semibold text-gray-900 text-sm mb-1">专业品质</h4>
          <p class="text-xs text-gray-500">多种风格模板，输出专业级内容</p>
        </div>
        <div class="bg-white rounded-xl border border-gray-100 p-4 text-center">
          <div class="w-10 h-10 bg-purple-100 rounded-xl flex items-center justify-center mx-auto mb-3">
            <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>
            </svg>
          </div>
          <h4 class="font-semibold text-gray-900 text-sm mb-1">灵活定制</h4>
          <p class="text-xs text-gray-500">支持编辑调整，自由切换风格</p>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <footer class="text-center text-xs text-gray-400 py-6 border-t border-gray-100">
      <p>Powered by 豆包大模型 · Built with Astro & Tailwind CSS</p>
    </footer>
  </div>
</Layout>
