---
import Layout from '../layouts/Layout.astro';
---

<Layout title="工作汇报生成器 - AI PPT & 汇报生成器" currentPage="report">
  <div class="max-w-3xl mx-auto px-6 py-8">
    <!-- AI Greeting -->
    <div class="flex gap-3 mb-6">
      <div class="w-9 h-9 rounded-xl flex items-center justify-center shrink-0 shadow-lg" style="background: linear-gradient(135deg, #10b981 0%, #0d9488 100%)">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
      </div>
      <div class="px-5 py-3 rounded-2xl border border-emerald-100 max-w-xl" style="background: linear-gradient(135deg, #f0fdf4 0%, #f8fafc 100%)">
        <p class="text-sm text-gray-700">📝 告诉我你的工作内容，我来帮你生成专业的工作汇报。</p>
      </div>
    </div>

    <!-- Input Section (User "message") -->
    <div class="bg-white rounded-2xl border border-gray-200 p-5 mb-6 shadow-sm no-print">
      <div class="flex items-center gap-2 mb-4">
        <div class="w-6 h-6 bg-blue-100 rounded-lg flex items-center justify-center">
          <svg class="w-3.5 h-3.5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        </div>
        <h3 class="text-sm font-bold text-gray-900">汇报配置</h3>
      </div>

      <div class="grid md:grid-cols-2 gap-4 mb-4">
        <!-- Report Type -->
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1.5 uppercase tracking-wide">汇报类型</label>
          <div class="grid grid-cols-4 gap-1.5">
            <button onclick="selectReportType('weekly')" class="report-type-btn active px-2 py-1.5 text-xs rounded-lg border-2 border-emerald-500 bg-emerald-50 text-emerald-700 font-medium" data-type="weekly">周报</button>
            <button onclick="selectReportType('monthly')" class="report-type-btn px-2 py-1.5 text-xs rounded-lg border-2 border-transparent bg-gray-50 text-gray-600 hover:border-gray-300" data-type="monthly">月报</button>
            <button onclick="selectReportType('quarterly')" class="report-type-btn px-2 py-1.5 text-xs rounded-lg border-2 border-transparent bg-gray-50 text-gray-600 hover:border-gray-300" data-type="quarterly">季度</button>
            <button onclick="selectReportType('yearly')" class="report-type-btn px-2 py-1.5 text-xs rounded-lg border-2 border-transparent bg-gray-50 text-gray-600 hover:border-gray-300" data-type="yearly">年度</button>
          </div>
        </div>

        <!-- Style -->
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1.5 uppercase tracking-wide">表达风格</label>
          <select id="report-style" class="w-full px-3 py-1.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none bg-gray-50">
            <option value="structured">结构化 - 标题+要点+数据</option>
            <option value="natural">自然表达 - 口语化但专业</option>
            <option value="upward">向上管理 - 突出成果和价值</option>
            <option value="okr">OKR - 目标-关键结果-进展</option>
            <option value="star">STAR - 情境-任务-行动-结果</option>
          </select>
        </div>
      </div>

      <!-- Work Points -->
      <div class="mb-4">
        <label class="block text-xs font-medium text-gray-500 mb-1.5 uppercase tracking-wide">工作内容要点 *</label>
        <div id="points-container" class="space-y-2 mb-2">
          <div class="flex gap-2">
            <input type="text" placeholder="输入工作要点，如：完成用户增长系统优化" class="point-input flex-1 px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none bg-gray-50 focus:bg-white transition-smooth" />
            <button onclick="removePoint(this)" class="p-2 text-gray-300 hover:text-red-500 transition-smooth hidden">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
          </div>
        </div>
        <button onclick="addPoint()" class="flex items-center gap-1 text-xs text-emerald-600 hover:text-emerald-700 font-medium">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
          添加要点
        </button>
      </div>

      <!-- Extra Info -->
      <div class="grid md:grid-cols-3 gap-3 mb-5">
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1">下期计划</label>
          <textarea id="report-plan" rows="2" placeholder="下周的工作计划..." class="w-full px-3 py-1.5 border border-gray-200 rounded-lg text-xs focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none resize-none bg-gray-50 focus:bg-white transition-smooth"></textarea>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1">遇到的问题</label>
          <textarea id="report-problems" rows="2" placeholder="遇到的困难或问题..." class="w-full px-3 py-1.5 border border-gray-200 rounded-lg text-xs focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none resize-none bg-gray-50 focus:bg-white transition-smooth"></textarea>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1">需要的支持</label>
          <textarea id="report-support" rows="2" placeholder="需要的资源或支持..." class="w-full px-3 py-1.5 border border-gray-200 rounded-lg text-xs focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none resize-none bg-gray-50 focus:bg-white transition-smooth"></textarea>
        </div>
      </div>

      <!-- Generate Button -->
      <button id="btn-gen-report" onclick="generateReport()" class="w-full py-2.5 bg-emerald-600 text-white font-medium rounded-xl hover:bg-emerald-700 transition-smooth flex items-center justify-center gap-2 shadow-lg shadow-emerald-500/20">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        生成汇报
      </button>
    </div>

    <!-- Result Section (AI "response") -->
    <div id="result-section" class="hidden">
      <!-- Action Bar -->
      <div class="bg-white rounded-t-2xl border border-b-0 border-gray-200 px-5 py-3 flex items-center justify-between no-print">
        <div class="flex items-center gap-3">
          <div class="ai-avatar w-6 h-6 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, #10b981 0%, #0d9488 100%)">
            <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
          <h3 class="text-sm font-bold text-gray-900">汇报内容已生成</h3>
          <div id="style-switcher" class="flex items-center gap-1 ml-3">
            <span class="text-[10px] text-gray-400">切换风格：</span>
            <button onclick="switchStyle('structured')" class="style-switch-btn px-1.5 py-0.5 text-[10px] rounded border border-emerald-500 bg-emerald-50 text-emerald-700" data-style="structured">结构化</button>
            <button onclick="switchStyle('natural')" class="style-switch-btn px-1.5 py-0.5 text-[10px] rounded border border-transparent text-gray-400 hover:bg-gray-100" data-style="natural">自然</button>
            <button onclick="switchStyle('upward')" class="style-switch-btn px-1.5 py-0.5 text-[10px] rounded border border-transparent text-gray-400 hover:bg-gray-100" data-style="upward">向上管理</button>
            <button onclick="switchStyle('okr')" class="style-switch-btn px-1.5 py-0.5 text-[10px] rounded border border-transparent text-gray-400 hover:bg-gray-100" data-style="okr">OKR</button>
            <button onclick="switchStyle('star')" class="style-switch-btn px-1.5 py-0.5 text-[10px] rounded border border-transparent text-gray-400 hover:bg-gray-100" data-style="star">STAR</button>
          </div>
        </div>
        <div class="flex items-center gap-1.5">
          <button onclick="toggleEdit()" id="btn-edit" class="px-2.5 py-1.5 text-xs border border-gray-200 rounded-lg hover:bg-gray-50 transition-smooth flex items-center gap-1">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            编辑
          </button>
          <button onclick="copyReport()" class="px-2.5 py-1.5 text-xs border border-gray-200 rounded-lg hover:bg-gray-50 transition-smooth flex items-center gap-1">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>
            复制
          </button>
          <button onclick="exportMarkdown()" class="px-2.5 py-1.5 text-xs border border-gray-200 rounded-lg hover:bg-gray-50 transition-smooth flex items-center gap-1">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            MD
          </button>
          <button onclick="exportWord()" class="px-2.5 py-1.5 text-xs border border-gray-200 rounded-lg hover:bg-gray-50 transition-smooth flex items-center gap-1">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
            Word
          </button>
          <button onclick="window.print()" class="px-2.5 py-1.5 text-xs border border-gray-200 rounded-lg hover:bg-gray-50 transition-smooth flex items-center gap-1">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
            打印
          </button>
        </div>
      </div>

      <!-- Report Content -->
      <div class="bg-white rounded-b-2xl border border-gray-200 p-6 min-h-[300px] shadow-sm">
        <div id="report-rendered" class="prose prose-sm max-w-none"></div>
        <textarea id="report-editor" class="hidden w-full min-h-[300px] p-4 border border-gray-200 rounded-lg text-sm font-mono focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none resize-none"></textarea>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div id="toast" class="fixed bottom-6 right-6 bg-gray-900 text-white px-4 py-2 rounded-lg text-sm shadow-lg transform translate-y-20 opacity-0 transition-smooth z-50"></div>

  <script src="../scripts/report.js"></script>
</Layout>
